BASE_URL=https://studio-api.suno.ai
SUNO_MODEL=chirp-fenix
# Optional override. chirp-fenix uses /api/generate/v2-web/ by default;
# legacy models use /api/generate/v2/.
# SUNO_GENERATE_PATH=/api/generate/v2-web/
SESSION_ID=
COOKIE=

# 영상 편집 화면에서 사용할 PNG/JPG/WebP/SVG 아이콘 폴더입니다.
# 기본값은 이 프로젝트의 images 폴더입니다.
# VIDEO_ICON_DIR=C:\path\to\video-icons
# SVG 영상 합성에 사용할 Edge/Chrome 실행 파일을 직접 지정할 수 있습니다.
# VIDEO_SVG_BROWSER=C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe

